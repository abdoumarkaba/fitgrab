# aria2c log line patterns for parsing progress
ARIA2_PROGRESS_PATTERN = re.compile(
    r'\[(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})\].*?'
    r'(DOWNLOAD_COMPLETE|DOWNLOAD_ERROR|DOWNLOAD_PROGRESS).*?'
    r'gid=([a-f0-9]+).*?'
    r'(?:filename=([^\s]+))?'
    r'(?:totalLength=(\d+))?'
    r'(?:completedLength=(\d+))?'
    r'(?:downloadSpeed=(\d+))?'
)
ARIA2_FILENAME_PATTERN = re.compile(r'filename=([^\s,]+)')


def parse_aria2_log_line(line: str) -> dict | None:
    """Parse a single aria2c log line for progress info.
    
    Returns dict with: event, gid, filename, total, completed, speed
    or None if line is not a progress line.
    """
    if 'DOWNLOAD_' not in line:
        return None
    
    result = {'event': None, 'gid': None, 'filename': None, 
              'total': 0, 'completed': 0, 'speed': 0}
    
    if 'DOWNLOAD_COMPLETE' in line:
        result['event'] = 'complete'
    elif 'DOWNLOAD_ERROR' in line:
        result['event'] = 'error'
    elif 'DOWNLOAD_PROGRESS' in line:
        result['event'] = 'progress'
    else:
        return None
    
    # Extract gid
    gid_match = re.search(r'gid=([a-f0-9]+)', line)
    if gid_match:
        result['gid'] = gid_match.group(1)
    
    # Extract filename
    fname_match = ARIA2_FILENAME_PATTERN.search(line)
    if fname_match:
        result['filename'] = fname_match.group(1)
    
    # Extract sizes
    total_match = re.search(r'totalLength=(\d+)', line)
    if total_match:
        result['total'] = int(total_match.group(1))
    
    completed_match = re.search(r'completedLength=(\d+)', line)
    if completed_match:
        result['completed'] = int(completed_match.group(1))
    
    speed_match = re.search(r'downloadSpeed=(\d+)', line)
    if speed_match:
        result['speed'] = int(speed_match.group(1))
    
    return result


async def monitor_aria2_progress(
    log_path: Path, 
    total_files: int,
    stop_event: asyncio.Event,
    progress_data: dict,
) -> None:
    """Monitor aria2c log file and update progress data dict.
    
    progress_data is a shared dict updated with:
    - files: {gid: {filename, total, completed, speed, status}}
    - completed_count: int
    - total_bytes: int
    - completed_bytes: int
    - current_speed: int
    """
    progress_data['files'] = {}
    progress_data['completed_count'] = 0
    progress_data['total_bytes'] = 0
    progress_data['completed_bytes'] = 0
    progress_data['current_speed'] = 0
    
    # Wait for log file to be created
    while not log_path.exists() and not stop_event.is_set():
        await asyncio.sleep(0.1)
    
    if stop_event.is_set():
        return
    
    # Tail the log file
    with open(log_path, 'r') as f:
        # Seek to end initially (skip existing content)
        f.seek(0, 2)
        
        while not stop_event.is_set():
            line = f.readline()
            if not line:
                await asyncio.sleep(0.1)
                continue
            
            parsed = parse_aria2_log_line(line)
            if not parsed:
                continue
            
            gid = parsed['gid']
            if not gid:
                continue
            
            if parsed['event'] == 'complete':
                if gid in progress_data['files']:
                    progress_data['files'][gid]['status'] = 'complete'
                    progress_data['completed_count'] += 1
            elif parsed['event'] == 'error':
                if gid in progress_data['files']:
                    progress_data['files'][gid]['status'] = 'error'
            elif parsed['event'] == 'progress':
                if gid not in progress_data['files']:
                    progress_data['files'][gid] = {
                        'filename': parsed['filename'] or f'file_{gid[:6]}',
                        'total': parsed['total'],
                        'completed': 0,
                        'speed': 0,
                        'status': 'downloading',
                    }
                
                progress_data['files'][gid]['completed'] = parsed['completed']
                progress_data['files'][gid]['speed'] = parsed['speed']
                
                if parsed['total'] > 0:
                    progress_data['files'][gid]['total'] = parsed['total']


def render_progress_display(progress_data: dict, total_files: int) -> str:
    """Render a simple progress display for non-Rich terminals."""
    lines = []
    lines.append(f"\n  Downloads: {progress_data['completed_count']}/{total_files} complete")
    
    total_bytes = 0
    completed_bytes = 0
    speed = 0
    
    for gid, info in progress_data.get('files', {}).items():
        if info['status'] == 'downloading':
            total_bytes += info['total']
            completed_bytes += info['completed']
            speed += info['speed']
            pct = (info['completed'] / info['total'] * 100) if info['total'] > 0 else 0
            fname = info['filename'][:40]
            lines.append(f"    {fname}: {pct:.1f}% ({format_size(info['completed'])}/{format_size(info['total'])})")
    
    if speed > 0:
        lines.append(f"  Speed: {format_speed(speed)}")
    
    return '\n'.join(lines)


