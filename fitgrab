# ── Incomplete Download Detection ─────────────────────────────────────────────

def scan_for_incomplete_downloads(base_paths: list[Path]) -> list[dict]:
    """Scan directories for incomplete downloads.
    
    Detection criteria:
    - Directory contains .fitgrab_queue.txt (aria2 queue file)
    - Directory contains .aria2 control files (incomplete downloads)
    
    Returns list of dicts with:
    - path: Path to game directory
    - game_name: extracted from directory or files
    - total_files: count from queue file or aria2 files
    - completed_files: count of complete .rar files
    - last_modified: timestamp of most recent file
    """
    incomplete = []
    
    for base_path in base_paths:
        if not base_path.exists():
            continue
        
        try:
            for item in base_path.iterdir():
                if not item.is_dir():
                    continue
                
                # Check for incomplete indicators
                queue_file = item / ".fitgrab_queue.txt"
                aria2_files = list(item.glob("*.aria2"))
                log_file = item / ".fitgrab_aria2.log"
                
                has_queue = queue_file.exists()
                has_aria2 = len(aria2_files) > 0
                
                if not (has_queue or has_aria2):
                    continue
                
                # Extract game name
                game_name = item.name.replace('_', ' ').title()
                for f in item.iterdir():
                    if f.suffix == ".rar" and not f.name.endswith(".aria2"):
                        match = re.match(r'^(.+?)_--_', f.name)
                        if match:
                            game_name = match.group(1).replace('_', ' ')
                            break
                
                # Count files
                total_files = 0
                if has_queue:
                    try:
                        with open(queue_file, 'r') as f:
                            content = f.read()
                            total_files = content.count("http")
                    except OSError:
                        pass
                
                # Count completed files
                completed_files = 0
                for f in item.iterdir():
                    if f.suffix == ".rar" and not f.name.endswith(".aria2"):
                        completed_files += 1
                
                # Get last modified time
                last_modified = 0.0
                try:
                    if log_file.exists():
                        last_modified = log_file.stat().st_mtime
                    elif has_queue:
                        last_modified = queue_file.stat().st_mtime
                    else:
                        last_modified = item.stat().st_mtime
                except OSError:
                    pass
                
                incomplete.append({
                    'path': item,
                    'game_name': game_name,
                    'total_files': total_files,
                    'completed_files': completed_files,
                    'last_modified': datetime.fromtimestamp(last_modified),
                })
        
        except PermissionError as e:
            logger.warning(f"Permission denied scanning {base_path}: {e}")
        except OSError as e:
            logger.warning(f"Error scanning {base_path}: {e}")
    
    # Sort by last modified (most recent first)
    incomplete.sort(key=lambda x: x['last_modified'], reverse=True)
    
    return incomplete


