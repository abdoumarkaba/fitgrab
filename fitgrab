# ── Rate-limit bypass constants ────────────────────────────────────────────────
# These values tune the backoff strategy when FuckingFast throttles requests.
# The CDN uses a sliding window - we back off to let it clear before retrying.

MAX_ATTEMPTS        = 5     # maximum total attempts per URL across the retry queue
COOLDOWN_AFTER_429  = 20    # base seconds a worker pauses after detecting a hard limit
BACKOFF_BASE        = 3.0   # seconds; doubles each attempt
BACKOFF_CAP         = 60.0  # maximum ceiling for a single backoff draw

# HTML substrings that indicate we've hit a rate limit (case-insensitive checked)
RATE_LIMIT_SIGNALS = [
    "rate limit",
    "too many requests",
    "429",
    "please slow down",
    "try again later",
    "access denied",
]

# Parallel browser contexts used during Stage 3 URL resolution.
DEFAULT_CONCURRENCY = 2

# ── aria2c configuration ─────────────────────────────────────────────────────────
# aria2c handles the actual file downloads. These settings are tuned for:
# - Single connection per file (ARIA2_SPLIT=1) to avoid HTTP Range header issues
#   with FuckingFast's CDN which doesn't properly support partial content.
# - Resume support (--continue=true) so re-running picks up where it left off.
# - Reasonable timeouts to detect stalled connections quickly.

ARIA2_CONCURRENT = 15
ARIA2_SPLIT = 1
ARIA2_MIN_SPLIT = "1M"
ARIA2_FILE_ALLOCATION = "none"
ARIA2_RETRY_WAIT = 5
ARIA2_MAX_TRIES = 6
ARIA2_TIMEOUT = 60
ARIA2_CONNECT_TIMEOUT = 15


# ── Signal handling ──────────────────────────────────────────────────────────────
# Graceful Ctrl+C handling - important because downloads can be long-running.
# We want a clean exit (code 0) rather than a crash, with a helpful message.

def _signal_handler(sig, frame):
    print("\n\n  ════════════════════════════════════════╗")
    print("  ║  Interrupted — re-run to resume        ║")
    print("  ════════════════════════════════════════╝\n")
    sys.exit(0)

signal.signal(signal.SIGINT, _signal_handler)


# ── Utilities ──────────────────────────────────────────────────────────────────

def slugify(title: str) -> str:
    """Turn a game title into a safe directory name.
    
    Removes brackets/parentheses content (like [Update] or (DLC), strips special
    chars, replaces spaces with underscores, truncates to 80 chars.
    """
    title = re.sub(r'[\[({][^\])})]*[\])})]', '', title)
    title = re.sub(r"[^\w\s\-]", "", title)
    title = re.sub(r'\s+', '_', title.strip())
    return title[:80]


def jittered_backoff(attempt: int) -> float:
    """Full-jitter exponential backoff for distributed retry timing.
    
    Why full jitter? If all failed requests retry at the same time, they create
    a new spike that triggers more rate limits. Randomizing across the full
    [0, ceiling] range spreads load and improves success rate.
    
    Timing: attempt=0 → 0-3s, attempt=1 → 0-6s, attempt=2 → 0-12s ... capped at 60s.
    """
    ceiling = min(BACKOFF_BASE * (2 ** attempt), BACKOFF_CAP)
    return random.uniform(0, ceiling)


def extract_game_name(direct_urls: list[str]) -> str | None:
    """Extract game name from first resolved URL.
    
    Filename format: <GameName>_--_fitgirl-repacks.site_--_.partNN.rar
    Extract everything before '_--_' to get the game name.
    """
    if not direct_urls:
        return None
    
    fname = direct_urls[0].split("/")[-1].split("?")[0]
    match = re.match(r'^(.+?)_--_', fname)
    if match:
        return match.group(1).replace('_', ' ')
    
    return None


def extract_filename_from_url(url: str) -> str:
    """Extract filename from a CDN URL.
    
    URL format: https://cdn.../filename?token=...
    Returns the filename portion.
    """
    return url.split("/")[-1].split("?")[0]


def save_ff_manifest(ff_links: list[str], dest_dir: Path, game_name: str) -> Path:
    """Save FF page URLs to a game-specific manifest file.
    
    Manifest stores FF page URLs (stable, no expiring tokens) not CDN URLs.
    This allows resume to re-resolve only missing files without stale URL failures.
    Manifest format: .<game_name>_ff_urls.txt
    Each line: one FF page URL
    Returns the manifest path.
    """
    manifest_path = dest_dir / f".{slugify(game_name)}_ff_urls.txt"
    with open(manifest_path, "w") as f:
        for url in ff_links:
            f.write(url + "\n")
    return manifest_path


def load_ff_manifest(dest_dir: Path, game_name: str) -> list[str] | None:
    """Load FF page URLs from a game-specific manifest file.
    
    Returns list of FF page URLs, or None if manifest doesn't exist.
    """
    manifest_path = dest_dir / f".{slugify(game_name)}_ff_urls.txt"
    if not manifest_path.exists():
        return None
    
    urls = []
    with open(manifest_path, "r") as f:
        for line in f:
            line = line.strip()
            if line:
                urls.append(line)
    return urls


def ff_manifest_path(dest_dir: Path, game_name: str) -> Path:
    """Return the path to the FF manifest file for this game."""
    return dest_dir / f".{slugify(game_name)}_ff_urls.txt"


def scan_existing_files(dest_dir: Path) -> set[str]:
    """Scan directory for existing complete RAR files.
    
    Returns set of filenames that are complete (no .aria2 control file).
    Files with .aria2 sidecar are incomplete and should be resumed.
    """
    if not dest_dir.exists():
        return set()
    
    complete = set()
    for f in dest_dir.iterdir():
        if f.suffix == ".rar" and not f.name.endswith(".aria2"):
            # Check if there's a .aria2 control file (incomplete)
            aria2_file = Path(str(f) + ".aria2")
            if not aria2_file.exists():
                complete.add(f.name)
    return complete


# ── Resume Integrity Module ───────────────────────────────────────────────────
# Provides utilities to detect and clean corrupted aria2 resume state.
# Corrupted .aria2 files cause aria2c to fail immediately with:
#   "Failed to read from the segment file ... .aria2"
# This module should be called before scan_existing_files() to ensure
# clean resume state.

def is_aria2_control_valid(aria2_path: Path) -> bool:
    """Check if an aria2 control file is readable and non-corrupted.
    
    aria2c uses a binary format. Corruption typically manifests as:
    - Empty or 0-byte files
    - Files with unreadable segment data
    - Files where associated .rar doesn't exist or is 0 bytes
    
    This is a heuristic check - we verify basic structural integrity
    rather than full binary parsing.
    """
    if not aria2_path.exists():
        return False
    
    # Must have content (0-byte control files are definitely broken)
    if aria2_path.stat().st_size == 0:
        return False
    
    # Must be readable binary file (at least 16 bytes for header)
    try:
        if aria2_path.stat().st_size < 16:
            return False
    except OSError:
        return False
    
    return True


def clean_corrupted_resume_state(dest_dir: Path) -> tuple[int, int]:
    """Clean corrupted aria2 resume files and their broken partial downloads.
    
    Scans directory for .aria2 control files. For each:
    - If control file is corrupted/empty: delete it AND associated .rar
    - If associated .rar is 0 bytes: delete both
    - If .rar doesn't exist: delete the orphaned .aria2
    
    Returns tuple of (aria2_files_removed, rar_files_removed).
    
    This prevents the aria2c error:
        "Failed to read from the segment file ..."
    which causes all downloads to fail on resume.
    """
    if not dest_dir.exists():
        return (0, 0)
    
    aria2_removed = 0
    rar_removed = 0
    
    for f in dest_dir.iterdir():
        if not f.name.endswith(".aria2"):
            continue
        
        # Get associated .rar file path
        rar_path = Path(str(f)[:-len(".aria2")])  # Remove .aria2 suffix
        
        needs_cleanup = False
        
        # Case 1: aria2 control file itself is corrupted
        if not is_aria2_control_valid(f):
            needs_cleanup = True
        
        # Case 2: Associated .rar doesn't exist
        elif not rar_path.exists():
            needs_cleanup = True
        
        # Case 3: Associated .rar is 0 bytes (download never started properly)
        elif rar_path.stat().st_size == 0:
            needs_cleanup = True
        
        if needs_cleanup:
            try:
                f.unlink()
                aria2_removed += 1
            except OSError:
                pass
            
            # Also clean up the broken partial .rar if it exists
            if rar_path.exists():
                try:
                    rar_path.unlink()
                    rar_removed += 1
                except OSError:
                    pass
    
    return (aria2_removed, rar_removed)


def filter_missing_ff_links(ff_links: list[str], existing_files: set[str]) -> list[str]:
    """Filter FF page URLs to only those whose files don't exist on disk.
    
    Extracts the expected part number from each FF URL and checks if
    the corresponding .rar file exists in existing_files.
    Returns list of FF page URLs for files that need to be downloaded.
    """
    missing = []
    for url in ff_links:
        # FF URLs contain the filename in the path segment after the hash
        # e.g. https://fuckingfast.co/Hash/GameName_--_fitgirl_--_.part01.rar
        # Extract part number to match against existing files
        part_match = re.search(r'part(\d+)\.rar', url, re.IGNORECASE)
        if not part_match:
            # Can't determine part number, include it
            missing.append(url)
            continue
        
        part_num = part_match.group(1)
        # Check if any existing file matches this part number
        found = any(f'part{part_num}.rar' in fname for fname in existing_files)
        if not found:
            missing.append(url)
    return missing


def test_archive(dest_dir: Path, game_name: str) -> bool:
    """Test archive integrity using unrar on part01.rar.
    
    Only tests *.part01.rar file specifically.
    Saves output to <game_name>test.log in the game directory.
    Returns True if test passed, False otherwise.
    """
    # Find part01.rar specifically
    part01 = None
    for f in dest_dir.iterdir():
        if f.name.endswith(".part01.rar"):
            part01 = f
            break
    
    if not part01:
        print(f"  ⚠  No part01.rar found in {dest_dir}")
        return False
    
    # Check if unrar is available
    if not shutil.which("unrar"):
        print("  ⚠  unrar not found. Install: sudo apt install unrar")
        return False
    
    log_path = dest_dir / f"{slugify(game_name)}test.log"
    
    print(f"\n  → Testing archive integrity: {part01.name}")
    print(f"     Log: {log_path}")
    
    # Run unrar test and capture output
    cmd = ["unrar", "t", "-idp", str(part01)]
    result = subprocess.run(cmd, capture_output=True, text=True)
    
    # Write log file
    with open(log_path, "w") as f:
        f.write(f"Archive test: {part01.name}\n")
        f.write(f"Date: {datetime.now().isoformat()}\n")
        f.write(f"\n{'='*60}\n\n")
        f.write(result.stdout)
        if result.stderr:
            f.write(f"\nErrors:\n{result.stderr}")
        f.write(f"\n\n{'='*60}\n")
        f.write(f"Result: {'PASSED' if result.returncode == 0 else 'FAILED'}\n")
    
    if result.returncode == 0:
        print(f"  ✓  Archive test PASSED")
        return True
    else:
        print(f"  ✗  Archive test FAILED — see {log_path}")
        return False


# ── Stage 1+2: fitgirl page → PrivateBin paste → FF link list ─────────────────

async def get_ff_links(
    game_url: str,
    context,
    paste_url: str | None = None,
) -> tuple[str, list[str]]:
    """Extract download links from FitGirl repack page.
    
    Two-stage process:
    1. If no paste_url given: load game page, find PrivateBin link for FuckingFast
    2. Load the PrivateBin paste, wait for JS decryption, extract FF download URLs
    
    Returns tuple of (game_title, list_of_fuckingfast_urls)
    
    Note: PrivateBin uses client-side AES encryption - the #fragment in the URL
    contains the key. Server only sees encrypted blob, so we must use Playwright
    to execute the decryption JS and render the actual download links.
    """
    page = await context.new_page()
    try:
        if paste_url:
            title = "fitgirl_download"
        else:
            print("  → Loading game page…")
            await page.goto(game_url, wait_until="domcontentloaded", timeout=30_000)

            title_el = (
                await page.query_selector("h1.entry-title")
                or await page.query_selector("h1")
            )
            title = (
                await title_el.inner_text()
                if title_el
                else Path(game_url).stem.replace("-", " ").title()
            )

            paste_url = await page.eval_on_selector_all(
                "a[href*='paste.fitgirl-repacks.site']",
                """els => {
                    for (const el of els) {
                        if (el.closest('li') &&
                            el.closest('li').textContent.includes('FuckingFast')) {
                            return el.href;
                        }
                    }
                    return els.length ? els[0].href : null;
                }"""
            )

            if not paste_url:
                print("  ✗  No paste.fitgirl-repacks.site link found on game page.")
                return title, []

        # ── Stage 2: load the PrivateBin paste ───────────────────────────────
        print(f"  → Loading paste (PrivateBin, decrypting via JS)…")
        print(f"    {paste_url}")
        await page.goto(paste_url, wait_until="domcontentloaded", timeout=30_000)

        try:
            await page.wait_for_selector(
                "a[href*='fuckingfast.co']", timeout=15_000
            )
        except PWTimeout:
            print("  ✗  Paste page did not render FF links within 15s.")
            print("     Possible causes: wrong paste URL, PrivateBin JS failed,")
            print("     or the paste requires a password.")
            return title, []

        ff_links: list[str] = await page.eval_on_selector_all(
            "a[href*='fuckingfast.co']",
            "els => [...new Set(els.map(e => e.href))]"
        )

        if title == "fitgirl_download" and ff_links:
            first_link = ff_links[0]
            match = re.search(
                r'fuckingfast\.co/[^/]+/([^/]+?)(?:___|_part\d+)', first_link
            )
            title = (
                match.group(1).replace('_', ' ').title()
                if match
                else "fitgirl_download"
            )

        return title, ff_links

    finally:
        await page.close()


# ── Stage 3: resolve each FF page → real download URL ─────────────────────────

async def resolve_ff_url(
    page,
    ff_url: str,
    idx: int,
    total: int,
    attempt: int = 0,
) -> str | None:
    """Get direct CDN URL from a FuckingFast download page.
    
    The FF page has a flow: initial page → click download → ad popup appears → 
    close popup → click again → actual download starts. We use expect_download()
    to capture the final URL, then cancel the download (aria2c will handle it).
    
    Returns:
      - Direct download URL string on success
      - "__RATE_LIMITED__" sentinel when HTML contains rate-limit messages
      - "__RETRY__" sentinel on timeout or transient errors (retry may help)
      - None on hard failures (button not found, max attempts exhausted)
    
    The attempt counter is passed through so backoff widens globally - if we
    retry the same URL multiple times across different workers, each retry
    gets a longer wait than the last.
    """
    label = f"[{idx:02d}/{total:02d}]"

    if attempt > 0:
        wait = jittered_backoff(attempt - 1)
        print(f"  {label}  ↻  attempt {attempt + 1}/{MAX_ATTEMPTS}  "
              f"(backing off {wait:.1f}s…)")
        await asyncio.sleep(wait)

    try:
        await page.goto(ff_url, wait_until="networkidle", timeout=25_000)

        html = await page.content()
        if any(sig in html.lower() for sig in RATE_LIMIT_SIGNALS):
            print(f"  {label}  ⚠  Rate-limit signal detected")
            return "__RATE_LIMITED__"

        # Wait for Alpine.js to render — randomised to avoid rhythmic patterns
        await page.wait_for_timeout(random.randint(2500, 4500))

        # Debug: surface button state on first attempt only
        if attempt == 0:
            debug_info = await page.evaluate("""() => {
                const buttons = Array.from(document.querySelectorAll('button'));
                return {
                    count: buttons.length,
                    sample: buttons.slice(0, 6).map(b => ({
                        text: b.textContent.trim().slice(0, 50),
                        classes: b.className,
                        visible: b.offsetParent !== null
                    }))
                };
            }""")
            if debug_info["count"] == 0:
                print(f"  {label}  DEBUG: No buttons found; saving HTML snapshot…")
                html = await page.content()
                snap = Path(f"/tmp/fitgrab_debug_{idx}.html")
                snap.write_text(html)
                print(f"  {label}  DEBUG: {snap}")

        async with page.expect_download(timeout=18_000) as dl_info:
            clicked = await page.evaluate("""() => {
                const btn = Array.from(document.querySelectorAll('button')).find(b =>
                    b.textContent.toUpperCase().includes('DOWNLOAD') ||
                    b.classList.contains('link-button') ||
                    b.classList.contains('gay-button')
                );
                if (btn) {
                    btn.click();
                    return {found: true, text: btn.textContent.trim().slice(0, 30)};
                }
                return {found: false, count: document.querySelectorAll('button').length};
            }""")

        if not clicked.get("found"):
            print(f"  {label}  ✗  Download button not found "
                  f"({clicked.get('count', 0)} buttons on page)")
            return None

        dl = await dl_info.value
        url = dl.url
        await dl.cancel()

        fname = url.split("/")[-1].split("?")[0] or ff_url.split("#")[-1][:40]
        print(f"  {label}  ✓  {fname}")
        return url

    except PWTimeout:
        print(f"  {label}  ✗  Timeout (attempt {attempt + 1})")
        return "__RETRY__"
    except Exception as e:
        print(f"  {label}  ✗  {e}")
        return "__RETRY__"


async def resolve_all(ff_links: list[str], concurrency: int) -> list[str]:
    """Resolve all FuckingFast URLs to direct CDN links using parallel workers.
    
    Architecture:
    - Queue-based: each item is (original_index, url, attempt_number)
    - Worker pool: N concurrent browser contexts (controlled by concurrency param)
    - Per-attempt isolation: each attempt gets fresh UA, viewport, cookies
    - Retry logic: rate-limited URLs get cooldown before re-queue, timeouts
      retry immediately with backoff applied on next attempt
    - Result filtering: None values (failed after MAX_ATTEMPTS) are filtered out
    
    The retry queue is persistent in memory - if the process crashes mid-way,
    re-running will re-resolve everything. For true crash recovery, we'd need
    to persist the queue to disk (future enhancement).
    """
    queue: asyncio.Queue = asyncio.Queue()
    for i, url in enumerate(ff_links):
        await queue.put((i, url, 0))

    results: list[str | None] = [None] * len(ff_links)
    total = len(ff_links)
    sem = asyncio.Semaphore(concurrency)

    async with async_playwright() as pw:
        browser = await pw.chromium.launch(
            headless=True,
            args=[
                "--no-sandbox",
                "--disable-gpu",
                "--disable-dev-shm-usage",
                "--disable-blink-features=AutomationControlled",
                "--disable-web-security",
                "--disable-features=IsolateOrigins,site-per-process",
            ],
        )

        async def worker(worker_id: int):
            while True:
                try:
                    idx, url, attempt = queue.get_nowait()
                except asyncio.QueueEmpty:
                    break

                async with sem:
                    # Distinct context per attempt: different UA, viewport, cookies
                    ua = random.choice(USER_AGENTS)
                    context = await browser.new_context(
                        user_agent=ua,
                        accept_downloads=True,
                        viewport={
                            "width": random.randint(1280, 1920),
                            "height": random.randint(720, 1080),
                        },
                    )
                    # Block media to speed up page loads; we only need the DOM
                    await context.route(
                        re.compile(
                            r"\.(png|jpg|jpeg|gif|webp|svg|woff2?|ttf|mp4)(\?.*)?$"
                        ),
                        lambda r: r.abort(),
                    )
                    page = await context.new_page()

                    if STEALTH_AVAILABLE and stealth_async:
                        await stealth_async(page)

                    result = await resolve_ff_url(page, url, idx + 1, total, attempt)

                    await page.close()
                    await context.close()

                    if result == "__RATE_LIMITED__":
                        if attempt < MAX_ATTEMPTS - 1:
                            cooldown = COOLDOWN_AFTER_429 + random.uniform(0, 10)
                            print(
                                f"  [worker-{worker_id}]  ❄  "
                                f"Cooling {cooldown:.0f}s before retry…"
                            )
                            await asyncio.sleep(cooldown)
                            await queue.put((idx, url, attempt + 1))
                        else:
                            print(
                                f"  [{idx+1:02d}/{total:02d}]  ✗  "
                                f"Gave up after {MAX_ATTEMPTS} attempts (rate limit)"
                            )

                    elif result == "__RETRY__":
                        if attempt < MAX_ATTEMPTS - 1:
                            await queue.put((idx, url, attempt + 1))
                        else:
                            print(
                                f"  [{idx+1:02d}/{total:02d}]  ✗  "
                                f"Gave up after {MAX_ATTEMPTS} attempts"
                            )

                    elif result:
                        results[idx] = result

                queue.task_done()

        workers = [asyncio.create_task(worker(i)) for i in range(concurrency)]
        await asyncio.gather(*workers)
        await browser.close()

    return [r for r in results if r]


# ── Stage 4: aria2c ────────────────────────────────────────────────────────────

def aria2c_download(direct_urls: list[str], dest_dir: Path) -> bool:
    """Download files using aria2c with resume support.
    
    Writes an aria2c input file (URL + dir per line) and spawns aria2c as a
    subprocess. The --continue=true flag enables resuming partial downloads
    if the process is interrupted or fails.
    
    Key aria2c settings:
    - split=1: Single connection per file (required for FuckingFast CDN which
      doesn't properly support HTTP Range headers -会导致下载失败)
    - max-concurrent-downloads=3: Parallel file downloads
    - file-allocation=none: Skip pre-allocation (faster on SSD, avoids issues
      with sparse files)
    
    On success (returncode 0), cleans up queue file.
    Returns True on success, False on failure.
    """
    if not shutil.which("aria2c"):
        print("\n  ✗ aria2c not found.")
        print("  Install: sudo apt install aria2\n")
        sys.exit(1)

    dest_dir.mkdir(parents=True, exist_ok=True)

    input_path = dest_dir / ".fitgrab_queue.txt"
    with open(input_path, "w") as f:
        for url in direct_urls:
            f.write(url + "\n")
            f.write(f" dir={dest_dir}\n")

    log_path = dest_dir / ".fitgrab_aria2.log"

    cmd = [
        "aria2c",
        f"--input-file={input_path}",
        f"--max-concurrent-downloads={ARIA2_CONCURRENT}",
        f"--max-connection-per-server={ARIA2_SPLIT}",
        f"--split={ARIA2_SPLIT}",
        f"--min-split-size={ARIA2_MIN_SPLIT}",
        f"--file-allocation={ARIA2_FILE_ALLOCATION}",
        "--continue=true",
        f"--retry-wait={ARIA2_RETRY_WAIT}",
        f"--max-tries={ARIA2_MAX_TRIES}",
        f"--timeout={ARIA2_TIMEOUT}",
        f"--connect-timeout={ARIA2_CONNECT_TIMEOUT}",
        f"--user-agent={DEFAULT_USER_AGENT}",
        "--console-log-level=notice",
        "--summary-interval=15",
        "--download-result=full",
        f"--log={log_path}",
        "--log-level=warn",
    ]

    print(f"\n  → aria2c  [{len(direct_urls)} files → {dest_dir}]")
    print(f"     {ARIA2_CONCURRENT} concurrent × {ARIA2_SPLIT} connection/file  |  resume: yes")
    print(f"     log: {log_path}\n")
    print("  " + "─" * 60)

    result = subprocess.run(cmd)
    if result.returncode == 0:
        input_path.unlink(missing_ok=True)
        return True
    else:
        print(f"\n  ⚠  aria2c exited {result.returncode} — re-run fitgrab to resume.")
        return False


# ── Main ───────────────────────────────────────────────────────────────────────

async def run(args):
    """Main entry point - orchestrates the download pipeline.
    
    Stage 1+2: Load FitGirl page or use provided paste URL, extract FF links
    Stage 3: Resolve each FF page to get direct CDN URLs (parallel workers)
    Stage 4: Pass URLs to aria2c for actual file download
    Stage 5: Test archive integrity with unrar
    
    Resume flow: If an FF manifest exists in the target directory, skip
    Stage 1+2 and only resolve FF pages for files not already on disk.
    FF page URLs are stable (no expiring tokens), so the manifest is safe
    to reuse across restarts — unlike CDN URLs which would become stale.
    
    Game name is determined from CDN filenames after Stage 3, which is
    more reliable than the title placeholder from paste URLs.
    """
    print("\n  ╒══════════════════════════════════╮")
    print("  ║   fitgrab  —  FitGirl speed loader    ║")
    print("  ╚══════════════════════════════════╯\n")

    input_url = args.url
    direct_paste_url = None
    if "paste.fitgirl-repacks.site" in input_url:
        direct_paste_url = input_url
        print("  → Detected direct paste URL, skipping game page…")

    # ── Determine initial game name and directory ──────────────────────────
    # Use a preliminary name from the URL for manifest lookup.
    # The REAL game name is determined later from CDN filenames.
    preliminary_name = "fitgirl_download"
    if not direct_paste_url:
        # Extract slug from game page URL as preliminary name
        preliminary_name = Path(input_url).stem.replace("-", " ").title()

    if args.dir:
        dest_dir = Path(args.dir).expanduser()
    else:
        folder_name = slugify(preliminary_name)
        if folder_name:
            dest_dir = Path.home() / "Games" / folder_name
        else:
            dest_dir = Path.home() / "Games" / f"fitgirl_{datetime.now().strftime('%Y%m%d_%H%M%S')}"

    # ── Resume: check for existing FF manifest ──────────────────────────────
    # FF manifest stores stable FF page URLs (no expiring tokens).
    # If found, we skip Stage 1+2 entirely and only resolve missing files.
    ff_links = load_ff_manifest(dest_dir, preliminary_name)
    if ff_links:
        print(f"  → Found existing FF manifest, resuming…")
        print(f"  ✓  Parts : {len(ff_links)}")
    else:
        # Stage 1+2: one lightweight context just for scraping
        async with async_playwright() as pw:
            browser = await pw.chromium.launch(
                headless=True,
                args=["--no-sandbox", "--disable-gpu"],
            )
            context = await browser.new_context(user_agent=DEFAULT_USER_AGENT)
            title, ff_links = await get_ff_links(
                input_url, context, paste_url=direct_paste_url
            )
            await context.close()
            await browser.close()

        if not ff_links:
            print("\n  ✗  No FuckingFast links found. Check the game URL.\n")
            sys.exit(1)

        # Update preliminary name from title if we got one
        if title and title != "fitgirl_download":
            preliminary_name = title
            if not args.dir:
                folder_name = slugify(preliminary_name)
                if folder_name:
                    dest_dir = Path.home() / "Games" / folder_name
                else:
                    dest_dir = Path.home() / "Games" / f"fitgirl_{datetime.now().strftime('%Y%m%d_%H%M%S')}"

        print(f"\n  ✓  Game  : {preliminary_name}")
        print(f"  ✓  Parts : {len(ff_links)}")

        # Save FF manifest immediately for crash recovery
        dest_dir.mkdir(parents=True, exist_ok=True)
        save_ff_manifest(ff_links, dest_dir, preliminary_name)

    print(f"  ✓  Dest  : {dest_dir}")

    # ── Resume Integrity Check ─────────────────────────────────────────────
    # Clean corrupted aria2 resume state before scanning to prevent
    # "Failed to read from the segment file" errors on resume.
    aria2_cleaned, rar_cleaned = clean_corrupted_resume_state(dest_dir)
    if aria2_cleaned > 0 or rar_cleaned > 0:
        print(f"  → Cleaned {aria2_cleaned} corrupted resume file(s), {rar_cleaned} broken partial(s)")

    # ── Scan existing files and filter ─────────────────────────────────────
    existing_files = scan_existing_files(dest_dir)
    ff_to_resolve = filter_missing_ff_links(ff_links, existing_files)

    if existing_files:
        print(f"\n  → Found {len(existing_files)} complete files on disk")
        print(f"  → {len(ff_to_resolve)}/{len(ff_links)} files remaining")

    if args.dry_run:
        print("\n  [DRY RUN — FF page URLs]\n")
        for url in ff_links:
            part_match = re.search(r'part(\d+)\.rar', url, re.IGNORECASE)
            part_num = part_match.group(1) if part_match else "??"
            found = any(f'part{part_num}.rar' in fname for fname in existing_files) if part_match else False
            status = "✓ exists" if found else "↓ to download"
            print(f"    [{status}] part{part_num}")
        print()
        return

    # If all files already complete, skip download and test
    if not ff_to_resolve:
        print("\n  ✓  All files already downloaded!")
        # Determine real game name from existing files
        game_name = preliminary_name
        for f in dest_dir.iterdir():
            if f.suffix == ".rar" and not f.name.endswith(".aria2"):
                match = re.match(r'^(.+?)_--_', f.name)
                if match:
                    game_name = match.group(1).replace('_', ' ')
                    break
        test_archive(dest_dir, game_name)
        # Clean up manifest
        ff_manifest_path(dest_dir, preliminary_name).unlink(missing_ok=True)
        print(f"\n  ✓  Done!  →  {dest_dir}")
        print(f"  Extract: cd '{dest_dir}' && unrar x *.part01.rar\n")
        return

    sys.stdout.flush()

    # ── Stage 3: resolve only missing FF pages → CDN URLs ──────────────────
    print(f"\n  → Resolving {len(ff_to_resolve)} URLs "
          f"({args.concurrency} parallel contexts)…\n")

    direct_urls = await resolve_all(ff_to_resolve, args.concurrency)

    print(f"\n  ✓  Resolved : {len(direct_urls)}/{len(ff_to_resolve)}")
    failed = len(ff_to_resolve) - len(direct_urls)
    if failed:
        print(f"  ✗  Failed   : {failed}  (re-run fitgrab to retry)")

    if not direct_urls:
        print("\n  ✗  Nothing to download.\n")
        sys.exit(1)

    # ── Determine real game name from CDN filenames ────────────────────────
    # This is the reliable source — CDN filenames contain the game name
    # in the _--_ pattern, unlike the title placeholder from paste URLs.
    game_name = extract_game_name(direct_urls) or preliminary_name

    # Update directory if game name changed from preliminary
    if not args.dir and game_name != preliminary_name:
        folder_name = slugify(game_name)
        if folder_name:
            new_dir = Path.home() / "Games" / folder_name
            if new_dir != dest_dir:
                # Migrate manifest and any existing files to the correct directory
                print(f"\n  → Game name corrected: {preliminary_name} → {game_name}")
                print(f"  → Moving to: {new_dir}")
                if dest_dir.exists():
                    new_dir.mkdir(parents=True, exist_ok=True)
                    # Move FF manifest
                    old_manifest = ff_manifest_path(dest_dir, preliminary_name)
                    if old_manifest.exists():
                        old_manifest.rename(ff_manifest_path(new_dir, game_name))
                    # Move existing RAR files
                    for f in list(dest_dir.iterdir()):
                        if f.suffix == ".rar" or f.name.endswith(".aria2"):
                            f.rename(new_dir / f.name)
                    # Move aria2 log
                    old_log = dest_dir / ".fitgrab_aria2.log"
                    if old_log.exists():
                        old_log.rename(new_dir / ".fitgrab_aria2.log")
                dest_dir = new_dir
                # Re-scan after move, filter out already-downloaded files
                existing_files = scan_existing_files(dest_dir)
                direct_urls = [u for u in direct_urls
                               if extract_filename_from_url(u) not in existing_files]

    # ── Stage 4: download via aria2c ────────────────────────────────────────
    success = aria2c_download(direct_urls, dest_dir)

    if success:
        # Stage 5: test archive integrity
        test_archive(dest_dir, game_name)
        # Clean up FF manifest on success
        ff_manifest_path(dest_dir, game_name).unlink(missing_ok=True)
        print(f"\n  ✓  Done!  →  {dest_dir}")
        print(f"  Extract: cd '{dest_dir}' && unrar x *.part01.rar\n")
    else:
        print(f"\n  ✗  Download incomplete. Re-run fitgrab to resume.\n")


def main():
    parser = argparse.ArgumentParser(
        prog="fitgrab",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Examples:\n"
            "  fitgrab https://fitgirl-repacks.site/god-of-war-ragnarok/\n"
            "  fitgrab https://fitgirl-repacks.site/stellar-blade/ --dir ~/Games\n"
            "  fitgrab https://paste.fitgirl-repacks.site/?<id>#<key> --dir ~/Games\n"
            "  fitgrab <url> --dry-run"
        ),
    )
    parser.add_argument("url")
    parser.add_argument(
        "--dir",
        default=None,
        help="Download directory (default: auto-detect from filename → ~/Games/<game>/)",
    )
    parser.add_argument("--dry-run", action="store_true")
    parser.add_argument(
        "--concurrency",
        type=int,
        default=DEFAULT_CONCURRENCY,
        help=f"Parallel contexts for URL resolution (default: {DEFAULT_CONCURRENCY})",
    )
    args = parser.parse_args()
    asyncio.run(run(args))


if __name__ == "__main__":
    main()