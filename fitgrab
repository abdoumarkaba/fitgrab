def slugify(title: str) -> str:
    """Turn a game title into a safe directory name.
    
    Removes brackets/parentheses content (like [Update] or (DLC), strips special
    chars, replaces spaces with underscores, truncates to 80 chars.
    """
    title = re.sub(r'[\[({][^\])})]*[\])})]', '', title)
    title = re.sub(r"[^\w\s\-]", "", title)
    title = re.sub(r'\s+', '_', title.strip())
    return title[:80]


def jittered_backoff(attempt: int) -> float:
    """Full-jitter exponential backoff for distributed retry timing.
    
    Why full jitter? If all failed requests retry at the same time, they create
    a new spike that triggers more rate limits. Randomizing across the full
    [0, ceiling] range spreads load and improves success rate.
    
    Timing: attempt=0 → 0-3s, attempt=1 → 0-6s, attempt=2 → 0-12s ... capped at 60s.
    """
    ceiling = min(BACKOFF_BASE * (2 ** attempt), BACKOFF_CAP)
    return random.uniform(0, ceiling)


def get_default_dest_dir(game_name: str | None) -> Path:
    """Get default destination directory.
    
    Target: /run/media/abdoufoundit/forgames/extracted/<Game_Name>
    Creates the directory if it doesn't exist.
    """
    base_path = Path("/run/media/abdoufoundit/forgames/extracted")
    
    # Ensure base path exists (create if needed)
    base_path.mkdir(parents=True, exist_ok=True)
    
    if game_name:
        folder_name = slugify(game_name)
        return base_path / folder_name
    else:
        return base_path / f"fitgirl_{datetime.now().strftime('%Y%m%d_%H%M%S')}"


def extract_filename_from_url(url: str) -> str:
    """Extract filename from a CDN URL.
    
    URL format: https://cdn.../filename?token=...
    Returns the filename portion.
    """
    return url.split("/")[-1].split("?")[0]


def format_size(bytes_val: int) -> str:
    """Format bytes as human-readable size (MiB, GiB)."""
    if bytes_val >= 1024 * 1024 * 1024:
        return f"{bytes_val / (1024 * 1024 * 1024):.2f} GiB"
    elif bytes_val >= 1024 * 1024:
        return f"{bytes_val / (1024 * 1024):.1f} MiB"
    elif bytes_val >= 1024:
        return f"{bytes_val / 1024:.1f} KiB"
    return f"{bytes_val} B"


def format_speed(bytes_per_sec: float) -> str:
    """Format bytes/sec as human-readable speed."""
    if bytes_per_sec >= 1024 * 1024:
        return f"{bytes_per_sec / (1024 * 1024):.1f} MiB/s"
    elif bytes_per_sec >= 1024:
        return f"{bytes_per_sec / 1024:.1f} KiB/s"
    return f"{bytes_per_sec:.0f} B/s"


def format_time(seconds: float) -> str:
    """Format seconds as MM:SS or HH:MM:SS."""
    if seconds < 0:
        return "--:--"
    seconds = int(seconds)
    if seconds >= 3600:
        return f"{seconds // 3600:02d}:{(seconds % 3600) // 60:02d}:{seconds % 60:02d}"
    return f"{seconds // 60:02d}:{seconds % 60:02d}"


def truncate_path(path: str, max_len: int = 40) -> str:
    """Truncate a path for display, keeping the end visible."""
    if len(path) <= max_len:
        return path
    return "…" + path[-(max_len - 1):]


