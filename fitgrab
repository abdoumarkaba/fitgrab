def aria2c_download(direct_urls: list[str], dest_dir: Path, game_name: str = "download") -> bool:
    """Synchronous wrapper for aria2c_download_async."""
    return asyncio.run(aria2c_download_async(direct_urls, dest_dir, game_name))


def aria2c_resume(dest_dir: Path, concurrency: int = 8) -> bool:
    """Resume aria2 download using existing queue file with lower concurrency.
    
    This is used for --continue mode when downloads failed due to range header
    errors or network issues. It uses lower concurrency for stability.
    
    Args:
        dest_dir: Directory containing .fitgrab_queue.txt
        concurrency: Number of concurrent downloads (default 8 for stability)
    
    Returns True on success, False on failure.
    """
    input_path = dest_dir / ".fitgrab_queue.txt"
    if not input_path.exists():
        if RICH_AVAILABLE and console:
            console.print("\n[red]Error:[/red] No queue file found. Cannot resume.")
        else:
            print("\n  Error: No queue file found. Cannot resume.")
        return False

    log_path = dest_dir / ".fitgrab_aria2.log"

    cmd = [
        "aria2c",
        f"--input-file={input_path}",
        f"--max-concurrent-downloads={concurrency}",
        f"--max-connection-per-server={concurrency}",
        f"--split={concurrency}",
        f"--min-split-size=1M",
        "--file-allocation=none",
        "--continue=true",
        "--retry-wait=5",
        "--max-tries=6",
        "--timeout=60",
        "--connect-timeout=15",
        f"--user-agent={DEFAULT_USER_AGENT}",
        "--console-log-level=notice",
        "--summary-interval=15",
        "--download-result=full",
        f"--log={log_path}",
        "--log-level=warn",
    ]

    # Print download header
    if RICH_AVAILABLE and console:
        console.print()
        console.print(Panel(
            f"[dim]Resuming download[/dim] -> [cyan]{dest_dir}[/cyan]\n"
            f"[dim]{concurrency} concurrent | stable mode[/dim]",
            title="[bold green]Resume aria2c[/bold green]",
            border_style="green",
            expand=False,
        ))
    else:
        print(f"\n  Resuming aria2c -> {dest_dir}")
        print(f"  {concurrency} concurrent | stable mode")
        print(f"  log: {log_path}\n")

    # Run aria2c
    result = subprocess.run(cmd)

    # Check for completely missing files (files that were never started)
    missing_files = detect_missing_files(dest_dir)
    
    if missing_files:
        if RICH_AVAILABLE and console:
            console.print(f"\n[yellow]Detected {len(missing_files)} missing file(s), re-downloading...[/yellow]")
        else:
            print(f"\n  Detected {len(missing_files)} missing file(s), re-downloading...")
        # Re-run aria2c to download missing files
        result = subprocess.run(cmd)

    if result.returncode == 0:
        input_path.unlink(missing_ok=True)
        if RICH_AVAILABLE and console:
            console.print("\n[green]All downloads complete![/green]")
        else:
            print("\n  All downloads complete!")
        return True
    else:
        if RICH_AVAILABLE and console:
            console.print(f"\n[yellow]aria2c exited {result.returncode} - re-run fitgrab --continue[/yellow]")
        else:
            print(f"\n  aria2c exited {result.returncode} - re-run fitgrab --continue")
        return False


