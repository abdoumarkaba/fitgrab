                    if result == "__RATE_LIMITED__":
                        if attempt < MAX_ATTEMPTS - 1:
                            cooldown = COOLDOWN_AFTER_429 + random.uniform(0, 30)
                            print(
                                f"  [worker-{worker_id}]  ❄  "
                                f"Cooling {cooldown:.0f}s before retry…"
