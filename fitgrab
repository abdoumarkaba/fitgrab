def save_ff_manifest(ff_links: list[str], dest_dir: Path, game_name: str) -> Path:
    """Save FF page URLs to a game-specific manifest file.
    
    Manifest stores FF page URLs (stable, no expiring tokens) not CDN URLs.
    This allows resume to re-resolve only missing files without stale URL failures.
    Manifest format: .<game_name>_ff_urls.txt
    Each line: one FF page URL
    Returns the manifest path.
    """
    manifest_path = dest_dir / f".{slugify(game_name)}_ff_urls.txt"
    with open(manifest_path, "w") as f:
        for url in ff_links:
            f.write(url + "\n")
    return manifest_path


def load_ff_manifest(dest_dir: Path, game_name: str) -> list[str] | None:
    """Load FF page URLs from a game-specific manifest file.
    
    Returns list of FF page URLs, or None if manifest doesn't exist.
    """
    manifest_path = dest_dir / f".{slugify(game_name)}_ff_urls.txt"
    if not manifest_path.exists():
        return None
    
    urls = []
    with open(manifest_path, "r") as f:
        for line in f:
            line = line.strip()
            if line:
                urls.append(line)
    return urls


def ff_manifest_path(dest_dir: Path, game_name: str) -> Path:
    """Return the path to the FF manifest file for this game."""
    return dest_dir / f".{slugify(game_name)}_ff_urls.txt"


def scan_existing_files(dest_dir: Path) -> set[str]:
    """Scan directory for existing complete RAR files.
    
    Returns set of filenames that are complete (no .aria2 control file).
    Files with .aria2 sidecar are incomplete and should be resumed.
    """
    if not dest_dir.exists():
        return set()
    
    complete = set()
    for f in dest_dir.iterdir():
        if f.suffix == ".rar" and not f.name.endswith(".aria2"):
            # Check if there's a .aria2 control file (incomplete)
            aria2_file = Path(str(f) + ".aria2")
            if not aria2_file.exists():
                complete.add(f.name)
    return complete


# ── Resume Integrity Module ───────────────────────────────────────────────────
# Provides utilities to detect and clean corrupted aria2 resume state.
# Corrupted .aria2 files cause aria2c to fail immediately with:
#   "Failed to read from the segment file ... .aria2"
# This module should be called before scan_existing_files() to ensure
# clean resume state.

def is_aria2_control_valid(aria2_path: Path) -> bool:
    """Check if an aria2 control file is readable and non-corrupted.
    
    aria2c uses a binary format. Corruption typically manifests as:
    - Empty or 0-byte files
    - Files with unreadable segment data
    - Files where associated .rar doesn't exist or is 0 bytes
    
    This is a heuristic check - we verify basic structural integrity
    rather than full binary parsing.
    """
    if not aria2_path.exists():
        return False
    
    # Must have content (0-byte control files are definitely broken)
    if aria2_path.stat().st_size == 0:
        return False
    
    # Must be readable binary file (at least 16 bytes for header)
    try:
        if aria2_path.stat().st_size < 16:
            return False
    except OSError:
        return False
    
    return True


def clean_corrupted_resume_state(dest_dir: Path) -> tuple[int, int]:
    """Clean corrupted aria2 resume files and their broken partial downloads.
    
    Scans directory for .aria2 control files. For each:
    - If control file is corrupted/empty: delete it AND associated .rar
    - If associated .rar is 0 bytes: delete both
    - If .rar doesn't exist: delete the orphaned .aria2
    
    Returns tuple of (aria2_files_removed, rar_files_removed).
    
    This prevents the aria2c error:
        "Failed to read from the segment file ..."
    which causes all downloads to fail on resume.
    """
    if not dest_dir.exists():
        return (0, 0)
    
    aria2_removed = 0
    rar_removed = 0
    
    for f in dest_dir.iterdir():
        if not f.name.endswith(".aria2"):
            continue
        
        # Get associated .rar file path
        rar_path = Path(str(f)[:-len(".aria2")])  # Remove .aria2 suffix
        
        needs_cleanup = False
        
        # Case 1: aria2 control file itself is corrupted
        if not is_aria2_control_valid(f):
            needs_cleanup = True
        
        # Case 2: Associated .rar doesn't exist
        elif not rar_path.exists():
            needs_cleanup = True
        
        # Case 3: Associated .rar is 0 bytes (download never started properly)
        elif rar_path.stat().st_size == 0:
            needs_cleanup = True
        
        if needs_cleanup:
            try:
                f.unlink()
                aria2_removed += 1
            except OSError:
                pass
            
            # Also clean up the broken partial .rar if it exists
            if rar_path.exists():
                try:
                    rar_path.unlink()
                    rar_removed += 1
                except OSError:
                    pass
    
    return (aria2_removed, rar_removed)


def detect_range_header_errors(dest_dir: Path) -> list[Path]:
    """Detect files with range header errors by checking aria2 log.
    
    Range header errors (errorCode=8) occur when the server file size
    changed or the .aria2 control file has stale size info.
    
    Returns list of .rar file paths that need to be re-downloaded.
    """
    log_path = dest_dir / ".fitgrab_aria2.log"
    if not log_path.exists():
        return []
    
    corrupted_files = []
    
    try:
        with open(log_path, "r") as f:
            log_content = f.read()
        
        # Look for errorCode=8 (Invalid range header)
        # Pattern: errorCode=8 ... Request: X-Y/Z, Response: X-W/Z
        # Extract the filename from the path in the error message
        import re
        range_errors = re.findall(r'errorCode=8.*?path=([^\s]+)', log_content)
        
        for path in range_errors:
            # Extract filename from path
            filename = Path(path).name
            rar_path = dest_dir / filename
            if rar_path.exists():
                corrupted_files.append(rar_path)
    except Exception:
        pass
    
    return corrupted_files


def extract_expected_filenames_from_queue(queue_path: Path) -> set[str]:
    """Extract expected filenames from aria2 queue file.
    
    Queue file format:
    https://dl.fuckingfast.co/...
    dir=/path/to/dir
    
    Returns set of expected filenames (extracted from URLs).
    """
    if not queue_path.exists():
        return set()
    
    expected = set()
    
    try:
        with open(queue_path, "r") as f:
            lines = f.readlines()
        
        for line in lines:
            line = line.strip()
            if line and not line.startswith("dir="):
                # This is a URL line
                filename = extract_filename_from_url(line)
                if filename:
                    expected.add(filename)
    except Exception:
        pass
    
    return expected


def detect_missing_files(dest_dir: Path) -> list[str]:
    """Detect completely missing files by comparing against queue file.
    
    Files that were never started have no .aria2 control file, so aria2
    won't resume them automatically. This function detects those gaps.
    
    Returns list of missing filenames.
    """
    queue_path = dest_dir / ".fitgrab_queue.txt"
    expected = extract_expected_filenames_from_queue(queue_path)
    
    if not expected:
        return []
    
    existing = set()
    for f in dest_dir.iterdir():
        if f.suffix in [".rar", ".bin"]:
            existing.add(f.name)
    
    missing = sorted(expected - existing)
    return missing


def clean_range_header_errors(dest_dir: Path) -> tuple[int, int]:
    """Clean files with range header errors and their .aria2 control files.
    
    Returns tuple of (rar_files_removed, aria2_files_removed).
    """
    corrupted_files = detect_range_header_errors(dest_dir)
    
    rar_removed = 0
    aria2_removed = 0
    
    for rar_path in corrupted_files:
        # Delete the incomplete .rar file
        try:
            rar_path.unlink()
            rar_removed += 1
        except OSError:
            pass
        
        # Delete the .aria2 control file
        aria2_path = Path(str(rar_path) + ".aria2")
        if aria2_path.exists():
            try:
                aria2_path.unlink()
                aria2_removed += 1
            except OSError:
                pass
    
    return (rar_removed, aria2_removed)


def filter_missing_ff_links(ff_links: list[str], existing_files: set[str]) -> list[str]:
    """Filter FF page URLs to only those whose files don't exist on disk.
    
    Extracts the expected part number from each FF URL and checks if
    the corresponding .rar file exists in existing_files.
    Returns list of FF page URLs for files that need to be downloaded.
    """
    missing = []
    for url in ff_links:
        # FF URLs contain the filename in the path segment after the hash
        # e.g. https://fuckingfast.co/Hash/GameName_--_fitgirl_--_.part01.rar
        # Extract part number to match against existing files
        part_match = re.search(r'part(\d+)\.rar', url, re.IGNORECASE)
        if not part_match:
            # Can't determine part number, include it
            missing.append(url)
            continue
        
        part_num = part_match.group(1)
        # Check if any existing file matches this part number
        found = any(f'part{part_num}.rar' in fname for fname in existing_files)
        if not found:
            missing.append(url)
    return missing


def detect_optional_files(ff_links: list[str]) -> tuple[list[str], list[tuple[str, str]]]:
    """Separate FF links into core files and optional (selective) files.
    
    Optional files are identified by 'fg-' prefix in the filename.
    These include: voice packs, multiplayer components, selective DLCs.
    
    Returns:
        (core_links, optional_links) where optional_links is list of (url, filename)
    """
    core = []
    optional = []
    
    for url in ff_links:
        # Extract filename from URL
        decoded_path = unquote(url)
        # URL format: https://fuckingfast.co/<hash>/<filename>
        filename_match = re.search(r'fuckingfast\.co/[^/]+/(.+)$', decoded_path)
        filename = filename_match.group(1) if filename_match else url.split('/')[-1]
        
        # Check for optional file prefix (fg- or selective-)
        if filename.lower().startswith('fg-') or 'selective' in filename.lower():
            optional.append((url, filename))
        else:
            core.append(url)
    
    
    return core, optional


def prompt_optional_exclusion(optional_files: list[tuple[str, str]]) -> list[str]:
    """Display optional files and prompt user to exclude unwanted ones.
    
    Default behavior: download ALL optional files.
    User can enter indices of files to EXCLUDE.
    
    Returns list of URLs to KEEP (not excluded).
    """
    if not optional_files:
        return []
    
    if RICH_AVAILABLE and console:
        console.print("\n[bold yellow]Optional Files Detected[/bold yellow]")
        console.print("[dim]These are selective downloads (voice packs, multiplayer, DLCs).[/dim]")
        console.print("[dim]By default, ALL will be downloaded. Enter numbers to EXCLUDE.[/]\n")
        
        table = Table(show_header=True, header_style="bold")
        table.add_column("#", style="dim", width=4)
        table.add_column("Filename", style="cyan")
        for i, (_, filename) in enumerate(optional_files, 1):
            table.add_row(str(i), filename)
        console.print(table)
        
        console.print("\n[dim]Enter comma-separated numbers to exclude (e.g., 1,3,5)[/]")
        console.print("[dim]Press Enter to download all, or 'none' to exclude all optional files[/]\n")
    else:
        print("\n  Optional Files Detected:")
        print("  (selective downloads - voice packs, multiplayer, DLCs)")
        print("  By default, ALL will be downloaded. Enter numbers to EXCLUDE.\n")
        for i, (_, filename) in enumerate(optional_files, 1):
            print(f"    [{i}] {filename}")
        print("\n  Enter comma-separated numbers to exclude (e.g., 1,3,5)")
        print("  Press Enter to download all, or 'none' to exclude all optional files\n")
    
    try:
        user_input = input("  Exclude [Enter=all]: ").strip().lower()
        
        if user_input == "none":
            # Exclude all optional files
            return []
        elif not user_input:
            # Keep all optional files
            return [url for url, _ in optional_files]
        
        # Parse exclusion indices
        exclude_indices = set()
        for part in user_input.split(','):
            part = part.strip()
            if part.isdigit():
                idx = int(part)
                if 1 <= idx <= len(optional_files):
                    exclude_indices.add(idx - 1)  # Convert to 0-indexed
        
        # Keep files NOT in exclusion set
        kept_urls = []
        for i, (url, _) in enumerate(optional_files):
            if i not in exclude_indices:
                kept_urls.append(url)
        
        
        excluded_count = len(optional_files) - len(kept_urls)
        if RICH_AVAILABLE and console:
            console.print(f"\n[green]Keeping {len(kept_urls)} optional file(s), excluding {excluded_count}[/green]\n")
        else:
            print(f"  Keeping {len(kept_urls)} optional file(s), excluding {excluded_count}\n")
        
        return kept_urls
        
    except (EOFError, KeyboardInterrupt):
        # On interrupt, keep all optional files (default behavior)
        print("\n  Keeping all optional files.")
        return [url for url, _ in optional_files]


def test_archive(dest_dir: Path, game_name: str) -> bool:
    """Test archive integrity using unrar on part01.rar.
    
    Only tests the first GAME part (part1.rar), not optional files.
    Looks for files ending in part1.rar that don't start with fg- (selective files).
    Saves output to <game_name>test.log in the game directory.
    Returns True if test passed, False otherwise.
    """
    # Find first game part: matches part1, part01, part001, part0001 (ends with 1, next char is 0 or nothing)
    # Exclude fg-* files (optional/selective packs)
    # Must contain the game name (extracted from filename using _--_ pattern)
    game_part = None
    # Extract game name pattern from game_name for matching (e.g., "Nier Automata" -> "nier" or "nier_automata")
    game_name_pattern = game_name.lower().replace(' ', '_')
    game_name_simple = game_name.split()[0].lower()  # First word only (e.g., "nier")
    for f in dest_dir.iterdir():
        # Check: not fg-, matches part1/01/001/0001
        if (not f.name.startswith("fg-") 
            and re.search(r'\.part(1|01|001|0001)\.rar$', f.name)):
            # Check if filename contains game name (either with underscores or as first word)
            fname_lower = f.name.lower()
            if game_name_pattern in fname_lower or game_name_simple in fname_lower.split('_')[0]:
                game_part = f
                break
    
    if not game_part:
        print_status(False, f"No game part1.rar found in {dest_dir}")
        return False
    
    # Check if unrar is available
    if not shutil.which("unrar"):
        print_status(False, "unrar not found. Install: sudo dnf install unrar")
        return False
    
    log_path = dest_dir / f"{slugify(game_name)}test.log"
    
    print_stage(5, f"Testing archive integrity: {game_part.name}")
    print_status(True, f"Log: {log_path}")
    
    # Run unrar test and capture output
    cmd = ["unrar", "t", "-idp", str(game_part)]
    result = subprocess.run(cmd, capture_output=True, text=True)
    
    # Write log file
    with open(log_path, "w") as f:
        f.write(f"Archive test: {game_part.name}\n")
        f.write(f"Date: {datetime.now().isoformat()}\n")
        f.write(f"\n{'='*60}\n\n")
        f.write(result.stdout)
        if result.stderr:
            f.write(f"\nErrors:\n{result.stderr}")
        f.write(f"\n\n{'='*60}\n")
        f.write(f"Result: {'PASSED' if result.returncode == 0 else 'FAILED'}\n")
    
    if result.returncode == 0:
        print_status(True, "Archive test PASSED")
        return True
    else:
        print_status(False, f"Archive test FAILED - see {log_path}")
        return False


# ── Stage 1+2: fitgirl page → PrivateBin paste → FF link list ─────────────────

async def get_ff_links(
    game_url: str,
    context,
    paste_url: str | None = None,
) -> tuple[str, list[str]]:
    """Extract download links from FitGirl repack page.
    
    Two-stage process:
    1. If no paste_url given: load game page, find PrivateBin link for FuckingFast
    2. Load the PrivateBin paste, wait for JS decryption, extract FF download URLs
    
    Returns tuple of (game_title, list_of_fuckingfast_urls)
    
    Note: PrivateBin uses client-side AES encryption - the #fragment in the URL
    contains the key. Server only sees encrypted blob, so we must use Playwright
    to execute the decryption JS and render the actual download links.
    """
    page = await context.new_page()
    try:
        if paste_url:
            title = "fitgirl_download"
        else:
            print("  → Loading game page…")
            await page.goto(game_url, wait_until="domcontentloaded", timeout=30_000)

            title_el = (
                await page.query_selector("h1.entry-title")
                or await page.query_selector("h1")
            )
            title = (
                await title_el.inner_text()
                if title_el
                else Path(game_url).stem.replace("-", " ").title()
            )

            paste_url = await page.eval_on_selector_all(
                "a[href*='paste.fitgirl-repacks.site']",
                """els => {
                    for (const el of els) {
                        if (el.closest('li') &&
                            el.closest('li').textContent.includes('FuckingFast')) {
                            return el.href;
                        }
                    }
                    return els.length ? els[0].href : null;
                }"""
            )

            if not paste_url:
                print("  ✗  No paste.fitgirl-repacks.site link found on game page.")
                return title, []

        # ── Stage 2: load the PrivateBin paste ───────────────────────────────
        print(f"  → Loading paste (PrivateBin, decrypting via JS)…")
        print(f"    {paste_url}")
        await page.goto(paste_url, wait_until="domcontentloaded", timeout=30_000)

        try:
            await page.wait_for_selector(
                "a[href*='fuckingfast.co']", timeout=15_000
            )
        except PWTimeout:
            print("  ✗  Paste page did not render FF links within 15s.")
            print("     Possible causes: wrong paste URL, PrivateBin JS failed,")
            print("     or the paste requires a password.")
            return title, []

        ff_links: list[str] = await page.eval_on_selector_all(
            "a[href*='fuckingfast.co']",
            "els => [...new Set(els.map(e => e.href))]"
        )

        if title == "fitgirl_download" and ff_links:
            first_link = ff_links[0]
            # URL-decode the path first, then extract game name
            # FF URL format: https://fuckingfast.co/<hash>/<GameName>_--_fitgirl-repacks.site_--_.part01.rar
            decoded_path = unquote(first_link)
            match = re.search(
                r'fuckingfast\.co/[^/]+/(.+?)_--_', decoded_path
            )
            title = (
                match.group(1).replace('_', ' ')
                if match
                else "fitgirl_download"
            )

        return title, ff_links

    finally:
        await page.close()


# ── Stage 3: resolve each FF page → real download URL ─────────────────────────

async def resolve_ff_url(
    page,
    ff_url: str,
    idx: int,
    total: int,
    attempt: int = 0,
) -> str | None:
    """Get direct CDN URL from a FuckingFast download page.
    
    The FF page has a flow: initial page → click download → ad popup appears → 
    close popup → click again → actual download starts. We use expect_download()
    to capture the final URL, then cancel the download (aria2c will handle it).
    
    Returns:
      - Direct download URL string on success
      - "__RATE_LIMITED__" sentinel when HTML contains rate-limit messages
      - "__RETRY__" sentinel on timeout or transient errors (retry may help)
      - None on hard failures (button not found, max attempts exhausted)
    
    The attempt counter is passed through so backoff widens globally - if we
    retry the same URL multiple times across different workers, each retry
    gets a longer wait than the last.
    """
    label = f"[{idx:02d}/{total:02d}]"

    if attempt > 0:
        wait = jittered_backoff(attempt - 1)
        print(f"  {label}  ↻  attempt {attempt + 1}/{MAX_ATTEMPTS}  "
              f"(backing off {wait:.1f}s…)")
        await asyncio.sleep(wait)

    try:
        await page.goto(ff_url, wait_until="networkidle", timeout=25_000)

        html = await page.content()
        if any(sig in html.lower() for sig in RATE_LIMIT_SIGNALS):
            print(f"  {label}  ⚠  Rate-limit signal detected")
            return "__RATE_LIMITED__"

        # Wait for Alpine.js to render — randomised to avoid rhythmic patterns
        await page.wait_for_timeout(random.randint(2500, 4500))

        # Debug: surface button state on first attempt only
        if attempt == 0:
            debug_info = await page.evaluate("""() => {
                const buttons = Array.from(document.querySelectorAll('button'));
                return {
                    count: buttons.length,
                    sample: buttons.slice(0, 6).map(b => ({
                        text: b.textContent.trim().slice(0, 50),
                        classes: b.className,
                        visible: b.offsetParent !== null
                    }))
                };
            }""")
            if debug_info["count"] == 0:
                print(f"  {label}  DEBUG: No buttons found; saving HTML snapshot…")
                html = await page.content()
                snap = Path(f"/tmp/fitgrab_debug_{idx}.html")
                snap.write_text(html)
                print(f"  {label}  DEBUG: {snap}")

        async with page.expect_download(timeout=18_000) as dl_info:
            clicked = await page.evaluate("""() => {
                const btn = Array.from(document.querySelectorAll('button')).find(b =>
                    b.textContent.toUpperCase().includes('DOWNLOAD') ||
                    b.classList.contains('link-button') ||
                    b.classList.contains('gay-button')
                );
                if (btn) {
                    btn.click();
                    return {found: true, text: btn.textContent.trim().slice(0, 30)};
                }
                return {found: false, count: document.querySelectorAll('button').length};
            }""")

        if not clicked.get("found"):
            print(f"  {label}  ✗  Download button not found "
                  f"({clicked.get('count', 0)} buttons on page)")
            return None

        dl = await dl_info.value
        url = dl.url
        await dl.cancel()

        fname = url.split("/")[-1].split("?")[0] or ff_url.split("#")[-1][:40]
        print(f"  {label}  ✓  {fname}")
        return url

    except PWTimeout:
        print(f"  {label}  ✗  Timeout (attempt {attempt + 1})")
        return "__RETRY__"
    except Exception as e:
        print(f"  {label}  ✗  {e}")
        return "__RETRY__"


async def resolve_all(ff_links: list[str], concurrency: int) -> list[str]:
    """Resolve all FuckingFast URLs to direct CDN links using parallel workers.
    
    Architecture:
    - Queue-based: each item is (original_index, url, attempt_number)
    - Worker pool: N concurrent browser contexts (controlled by concurrency param)
    - Per-attempt isolation: each attempt gets fresh UA, viewport, cookies
    - Enhanced stealth: timezone/locale spoofing, webRTC leak prevention
    - Retry logic: rate-limited URLs get cooldown before re-queue, timeouts
      retry immediately with backoff applied on next attempt
    - Result filtering: None values (failed after MAX_ATTEMPTS) are filtered out
    
    The retry queue is persistent in memory - if the process crashes mid-way,
    re-running will re-resolve everything. For true crash recovery, we'd need
    to persist the queue to disk (future enhancement).
    """
    queue: asyncio.Queue = asyncio.Queue()
    for i, url in enumerate(ff_links):
        await queue.put((i, url, 0))

    results: list[str | None] = [None] * len(ff_links)
    total = len(ff_links)
    sem = asyncio.Semaphore(concurrency)

    async with async_playwright() as pw:
        browser = await pw.chromium.launch(
            headless=True,
            args=[
                "--no-sandbox",
                "--disable-gpu",
                "--disable-dev-shm-usage",
                "--disable-blink-features=AutomationControlled",
                "--disable-web-security",
                "--disable-features=IsolateOrigins,site-per-process",
                "--disable-infobars",
                "--disable-background-networking",
                "--disable-breakpad",
                "--disable-component-update",
                "--disable-default-apps",
                "--disable-extensions",
                "--disable-sync",
                "--metrics-recording-only",
                "--no-first-run",
                "--no-default-browser-check",
                "--disable-hang-monitor",
                "--disable-prompt-on-repost",
                "--disable-client-side-phishing-detection",
                "--disable-popup-blocking",
                "--disable-translate",
                "--disable-plugins",
                "--disable-session-crashed-bubble",
                "--disable-search-engine-choice",
                "--hide-scrollbars",
                "--mute-audio",
                "--ignore-certificate-errors",
                "--ignore-ssl-errors",
                "--window-position=0,0",
            ],
        )

        async def worker(worker_id: int):
            while True:
                try:
                    idx, url, attempt = queue.get_nowait()
                except asyncio.QueueEmpty:
                    break

                async with sem:
                    # Distinct context per attempt: different UA, viewport, cookies
                    ua = random.choice(USER_AGENTS)
                    
                    # Random timezone and locale for better fingerprint diversity
                    timezones = [
                        "America/New_York", "America/Los_Angeles", "America/Chicago",
                        "Europe/London", "Europe/Paris", "Europe/Berlin",
                        "Asia/Tokyo", "Asia/Shanghai", "Australia/Sydney",
                    ]
                    locales = ["en-US", "en-GB", "de-DE", "fr-FR", "es-ES"]
                    
                    context = await browser.new_context(
                        user_agent=ua,
                        accept_downloads=True,
                        viewport={
                            "width": random.randint(1280, 1920),
                            "height": random.randint(720, 1080),
                        },
                        locale=random.choice(locales),
                        timezone_id=random.choice(timezones),
                        # Additional stealth settings
