def prompt_resume_selection(incomplete: list[dict]) -> list[dict]:
    """Prompt user to select which downloads to resume.
    
    Returns list of selected items.
    """
    if not incomplete:
        return []
    
    if RICH_AVAILABLE and console:
        console.print("\n[dim]Enter comma-separated numbers to resume (e.g., 1,3,5)[/dim]")
        console.print("[dim]Press Enter to resume all, or 'q' to quit[/dim]\n")
    else:
        print("\n  Enter comma-separated numbers to resume (e.g., 1,3,5)")
        print("  Press Enter to resume all, or 'q' to quit\n")
    
    try:
        user_input = input("  Resume [Enter=all]: ").strip().lower()
        
        if user_input == 'q':
            return []
        elif not user_input:
            return incomplete
        
        # Parse selection indices
        selected_indices = set()
        for part in user_input.split(','):
            part = part.strip()
            if part.isdigit():
                idx = int(part)
                if 1 <= idx <= len(incomplete):
                    selected_indices.add(idx - 1)
        
        return [incomplete[i] for i in sorted(selected_indices)]
    
    except (EOFError, KeyboardInterrupt):
        print("\n")
        return []


def format_time(seconds: float) -> str:
    """Format seconds as MM:SS or HH:MM:SS."""
    if seconds < 0:
        return "--:--"
    seconds = int(seconds)
    if seconds >= 3600:
        return f"{seconds // 3600:02d}:{(seconds % 3600) // 60:02d}:{seconds % 60:02d}"
    return f"{seconds // 60:02d}:{seconds % 60:02d}"


