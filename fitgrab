def get_config_dir() -> Path:
    """Get fitgrab config directory."""
    if platform.system() == "Windows":
        return Path.home() / "AppData" / "Local" / "fitgrab"
    else:
        return Path.home() / ".config" / "fitgrab"


def get_paths_config() -> Path:
    """Get path to the game paths config file."""
    return get_config_dir() / "paths.conf"


def load_game_paths() -> list[Path]:
    """Load saved game paths from config file.
    
    Returns list of paths, creating default config if needed.
    """
    config_path = get_paths_config()
    
    # Default paths
    default_paths = [Path.home() / "Games"]
    
    if not config_path.exists():
        return default_paths
    
    paths = []
    try:
        with open(config_path, 'r') as f:
            for line in f:
                line = line.strip()
                if line and not line.startswith('#'):
                    p = Path(line).expanduser()
                    if p.exists():
                        paths.append(p)
    except OSError:
        pass
    
    return paths if paths else default_paths


def save_game_paths(paths: list[Path]) -> None:
    """Save game paths to config file."""
    config_dir = get_config_dir()
    config_dir.mkdir(parents=True, exist_ok=True)
    config_path = get_paths_config()
    
    try:
        with open(config_path, 'w') as f:
            f.write("# fitgrab game paths - one directory per line\n")
            f.write("# These directories are scanned for incomplete downloads\n\n")
            for p in paths:
                f.write(str(p) + "\n")
    except OSError as e:
        logger.warning(f"Could not save config: {e}")


