async def run(args):
    """Main entry point - orchestrates the download pipeline.
    
    Stage 1+2: Load FitGirl page or use provided paste URL, extract FF links
    Stage 3: Resolve each FF page to get direct CDN URLs (parallel workers)
    Stage 4: Pass URLs to aria2c for actual file download
    Stage 5: Test archive integrity with unrar
    
    Resume flow: If an FF manifest exists in the target directory, skip
    Stage 1+2 and only resolve FF pages for files not already on disk.
    FF page URLs are stable (no expiring tokens), so the manifest is safe
    to reuse across restarts — unlike CDN URLs which would become stale.
    
    Game name is extracted from FF page URLs in Stage 1+2 (URL-decoded),
    which is more reliable than the title placeholder from paste URLs.
    
    --continue mode: Skip scraping, clean corrupted state, resume aria2.
    """
    start_time = time.time()
    
    # Print header
    if RICH_AVAILABLE and console:
        console.print(Panel(
            "[bold]FitGirl Repacks Downloader[/bold]\n"
            "[dim]via FuckingFast mirrors[/dim]",
            title=f"[bold green]fitgrab[/bold green] [dim]v{__version__}[/dim]",
            border_style="green",
            expand=False,
        ))
    else:
        print(f"\n  fitgrab v{__version__} - FitGirl speed loader\n")

    # --continue mode: skip scraping, clean and resume aria2
    if args.continue_download:
        if not args.dir:
            if RICH_AVAILABLE and console:
                console.print("\n[red]Error:[/red] --continue requires --dir to specify download directory.")
            else:
                print("\n  Error: --continue requires --dir to specify download directory.")
            sys.exit(1)
        
        dest_dir = Path(args.dir).expanduser()
        
        if not dest_dir.exists():
            if RICH_AVAILABLE and console:
                console.print(f"\n[red]Error:[/red] Directory does not exist: {dest_dir}")
            else:
                print(f"\n  Error: Directory does not exist: {dest_dir}")
            sys.exit(1)
        
        print_stage(1, "Continue mode - cleaning corrupted state...")
        
        # Clean corrupted resume state
        aria2_cleaned, rar_cleaned = clean_corrupted_resume_state(dest_dir)
        if aria2_cleaned > 0 or rar_cleaned > 0:
            print_status(True, f"Cleaned {aria2_cleaned} corrupted resume file(s), {rar_cleaned} broken partial(s)")
        
        # Clean range header errors
        rar_removed, aria2_removed = clean_range_header_errors(dest_dir)
        if rar_removed > 0 or aria2_removed > 0:
            print_status(True, f"Cleaned {rar_removed} range-header-corrupted file(s), {aria2_removed} aria2 control(s)")
        
        # Resume aria2
        print_stage(2, "Resuming aria2 download...")
        success = aria2c_resume(dest_dir, concurrency=8)
        
        if success:
            # Extract game name from existing files
            game_name = "fitgirl_download"
            for f in dest_dir.iterdir():
                if f.suffix == ".rar" and not f.name.endswith(".aria2") and not f.name.startswith("fg-"):
                    match = re.match(r'^(.+?)_--_', f.name)
                    if match:
                        game_name = match.group(1).replace('_', ' ')
                        break
            
            # Test archive
            test_archive(dest_dir, game_name)
            
            elapsed = time.time() - start_time
            if RICH_AVAILABLE and console:
                console.print(Panel(
                    f"[green]Done![/green] -> [cyan]{dest_dir}[/cyan]\n"
                    f"[dim]Time: {format_time(elapsed)}[/dim]\n"
                    f"[dim]Extract: cd '{dest_dir}' && unrar x *.part01.rar[/dim]",
                    title="[bold green]Complete[/bold green]",
                    border_style="green",
                    expand=False,
                ))
            else:
                print(f"\n  Done! -> {dest_dir}")
                print(f"  Time: {format_time(elapsed)}")
                print(f"  Extract: cd '{dest_dir}' && unrar x *.part01.rar\n")
        else:
            if RICH_AVAILABLE and console:
                console.print(Panel(
                    "[yellow]Download incomplete. Re-run fitgrab --continue.[/yellow]",
                    title="[bold red]Incomplete[/bold red]",
                    border_style="red",
                    expand=False,
                ))
            else:
                print("\n  Download incomplete. Re-run fitgrab --continue.\n")
        return

    input_url = args.url
    direct_paste_url = None
    if "paste.fitgirl-repacks.site" in input_url:
        direct_paste_url = input_url
        print_stage(1, "Detected direct paste URL, skipping game page...")

    # ── Determine initial game name and directory ──────────────────────────
    # Use a preliminary name from the URL for manifest lookup.
    # The REAL game name is determined later from CDN filenames.
    preliminary_name = "fitgirl_download"
    if not direct_paste_url:
        # Extract slug from game page URL as preliminary name
        preliminary_name = Path(input_url).stem.replace("-", " ").title()
    elif args.dir:
        # Use folder name from --dir argument when provided with direct paste URL
        preliminary_name = Path(args.dir).expanduser().name.replace("-", " ").title()

    if args.dir:
        dest_dir = Path(args.dir).expanduser()
    else:
        dest_dir = get_default_dest_dir(preliminary_name)

    # ── Resume: check for existing FF manifest ──────────────────────────────
    # FF manifest stores stable FF page URLs (no expiring tokens).
    # If found, we skip Stage 1+2 entirely and only resolve missing files.
    ff_links = load_ff_manifest(dest_dir, preliminary_name)
    if ff_links:
        print_stage(2, "Found existing FF manifest, resuming...")
        print_status(True, f"Parts: {len(ff_links)}")
    else:
        # Stage 1+2: one lightweight context just for scraping
        async with async_playwright() as pw:
            browser = await pw.chromium.launch(
                headless=True,
                args=["--no-sandbox", "--disable-gpu"],
            )
            context = await browser.new_context(user_agent=DEFAULT_USER_AGENT)
            title, ff_links = await get_ff_links(
                input_url, context, paste_url=direct_paste_url
            )
            await context.close()
            await browser.close()

        if not ff_links:
            print_status(False, "No FuckingFast links found. Check the game URL.")
            sys.exit(1)

        # Use title from get_ff_links (now URL-decoded) as the game name
        if title and title != "fitgirl_download":
            preliminary_name = title
            if not args.dir:
                dest_dir = get_default_dest_dir(preliminary_name)

        print_status(True, f"Game: {preliminary_name}")
        print_status(True, f"Parts: {len(ff_links)}")
        # Only show Dest when we have the real game name (not the fallback)
        if preliminary_name != "fitgirl_download":
            print_status(True, f"Dest: {dest_dir}")

        # ── Optional file selection ─────────────────────────────────────────
        # Detect and prompt for optional files before saving manifest
        core_links, optional_files = detect_optional_files(ff_links)
        if optional_files:
            kept_optional = prompt_optional_exclusion(optional_files)
            ff_links = core_links + kept_optional
            print_status(True, f"Final: {len(ff_links)} files ({len(core_links)} core + {len(kept_optional)} optional)")

        # Save FF manifest immediately for crash recovery
        dest_dir.mkdir(parents=True, exist_ok=True)
        save_ff_manifest(ff_links, dest_dir, preliminary_name)

    # ── Resume Integrity Check ─────────────────────────────────────────────
    # Clean corrupted aria2 resume state before scanning to prevent
    # "Failed to read from the segment file" errors on resume.
    aria2_cleaned, rar_cleaned = clean_corrupted_resume_state(dest_dir)
    if aria2_cleaned > 0 or rar_cleaned > 0:
        print(f"  → Cleaned {aria2_cleaned} corrupted resume file(s), {rar_cleaned} broken partial(s)")

    # ── Scan existing files and filter ─────────────────────────────────────
    existing_files = scan_existing_files(dest_dir)
    ff_to_resolve = filter_missing_ff_links(ff_links, existing_files)

    if existing_files:
        print_stage(2, f"Found {len(existing_files)} complete files on disk")
        print_status(True, f"{len(ff_to_resolve)}/{len(ff_links)} files remaining")

    if args.dry_run:
        if RICH_AVAILABLE and console:
            console.print("\n[bold yellow]DRY RUN - FF page URLs[/bold yellow]\n")
            table = Table(show_header=True, header_style="bold")
            table.add_column("Part", style="cyan")
            table.add_column("Status")
            for url in ff_links:
                part_match = re.search(r'part(\d+)\.rar', url, re.IGNORECASE)
                part_num = part_match.group(1) if part_match else "??"
                found = any(f'part{part_num}.rar' in fname for fname in existing_files) if part_match else False
                status = "[green]exists[/green]" if found else "[yellow]to download[/yellow]"
                table.add_row(f"part{part_num}", status)
            console.print(table)
        else:
            print("\n  [DRY RUN - FF page URLs]\n")
            for url in ff_links:
                part_match = re.search(r'part(\d+)\.rar', url, re.IGNORECASE)
                part_num = part_match.group(1) if part_match else "??"
                found = any(f'part{part_num}.rar' in fname for fname in existing_files) if part_match else False
                status = "exists" if found else "to download"
                print(f"    [{status}] part{part_num}")
        return

    # If all files already complete, skip download and test
    if not ff_to_resolve:
        print_status(True, "All files already downloaded!")
        # Determine real game name from existing files
        game_name = preliminary_name
        for f in dest_dir.iterdir():
            if f.suffix == ".rar" and not f.name.endswith(".aria2"):
                match = re.match(r'^(.+?)_--_', f.name)
                if match:
                    game_name = match.group(1).replace('_', ' ')
                    break
        test_archive(dest_dir, game_name)
        # Clean up manifest
        ff_manifest_path(dest_dir, preliminary_name).unlink(missing_ok=True)
        elapsed = time.time() - start_time
        if RICH_AVAILABLE and console:
            console.print(Panel(
                f"[green]Done![/green] -> [cyan]{dest_dir}[/cyan]\n"
                f"[dim]Time: {format_time(elapsed)}[/dim]\n"
                f"[dim]Extract: cd '{dest_dir}' && unrar x *.part01.rar[/dim]",
                title="[bold green]Complete[/bold green]",
                border_style="green",
                expand=False,
            ))
        else:
            print(f"\n  Done! -> {dest_dir}")
            print(f"  Time: {format_time(elapsed)}")
        return

    sys.stdout.flush()

    # ----- Stage 3: resolve FF page URLs to CDN links -----
    # Game name already determined in Stage 1+2 (URL-decoded from FF links)
    print_stage(3, f"Resolving {len(ff_to_resolve)} URLs ({args.concurrency} parallel contexts)...")

    direct_urls = await resolve_all(ff_to_resolve, args.concurrency)

    print_status(True, f"Resolved: {len(direct_urls)}/{len(ff_to_resolve)}")
    failed = len(ff_to_resolve) - len(direct_urls)
    if failed:
        print_status(False, f"Failed: {failed} (re-run fitgrab to retry)")

    if not direct_urls:
        print_status(False, "Nothing to download.")
        sys.exit(1)

    # Game name is already determined as preliminary_name from Stage 1+2
    game_name = preliminary_name

    # ----- Stage 4: download via aria2c -----────────────────────────────────────────
    success = aria2c_download(direct_urls, dest_dir, game_name)

    if success:
        # Stage 5: test archive integrity
        test_archive(dest_dir, game_name)
        # Clean up FF manifest on success
        ff_manifest_path(dest_dir, game_name).unlink(missing_ok=True)
        elapsed = time.time() - start_time
        if RICH_AVAILABLE and console:
            console.print(Panel(
                f"[green]Done![/green] -> [cyan]{dest_dir}[/cyan]\n"
                f"[dim]Time: {format_time(elapsed)}[/dim]\n"
                f"[dim]Extract: cd '{dest_dir}' && unrar x *.part01.rar[/dim]",
                title="[bold green]Complete[/bold green]",
                border_style="green",
                expand=False,
            ))
        else:
            print(f"\n  Done! -> {dest_dir}")
            print(f"  Time: {format_time(elapsed)}")
            print(f"  Extract: cd '{dest_dir}' && unrar x *.part01.rar\n")
    else:
        if RICH_AVAILABLE and console:
            console.print(Panel(
                "[yellow]Download incomplete. Re-run fitgrab to resume.[/yellow]",
                title="[bold red]Incomplete[/bold red]",
                border_style="red",
                expand=False,
            ))
        else:
            print("\n  Download incomplete. Re-run fitgrab to resume.\n")


def run_resume_mode():
    """Handle --resume flag: scan for incomplete downloads and prompt to resume."""
    start_time = time.time()
    
    # Print header
    if RICH_AVAILABLE and console:
        console.print(Panel(
            "[bold]Scanning for incomplete downloads[/bold]\n"
            "[dim]Checking all configured game paths[/dim]",
            title=f"[bold green]fitgrab[/bold green] [dim]v{__version__}[/dim]",
            border_style="green",
            expand=False,
        ))
    else:
        print(f"\n  fitgrab v{__version__} - Resume Mode")
        print("  Scanning for incomplete downloads...\n")
    
    # Load game paths
    game_paths = load_game_paths()
    
    # Prompt to add more paths
    game_paths = prompt_add_game_paths(game_paths)
    
    # Scan for incomplete downloads
    incomplete = scan_for_incomplete_downloads(game_paths)
    
    # Display results
    display_incomplete_downloads(incomplete)
    
    if not incomplete:
        return
    
    # Prompt for selection
    selected = prompt_resume_selection(incomplete)
    
    if not selected:
        if RICH_AVAILABLE and console:
            console.print("\n[dim]No downloads selected. Exiting.[/dim]")
        else:
            print("\n  No downloads selected. Exiting.")
        return
    
    # Resume each selected download
    for item in selected:
        dest_dir = item['path']
        game_name = item['game_name']
        
        if RICH_AVAILABLE and console:
            console.print(f"\n[bold cyan]Resuming: {game_name}[/bold cyan]")
            console.print(f"[dim]{dest_dir}[/dim]\n")
        else:
            print(f"\n  Resuming: {game_name}")
            print(f"  {dest_dir}\n")
        
        # Clean corrupted state
        aria2_cleaned, rar_cleaned = clean_corrupted_resume_state(dest_dir)
        if aria2_cleaned > 0 or rar_cleaned > 0:
            print_status(True, f"Cleaned {aria2_cleaned} corrupted resume file(s), {rar_cleaned} broken partial(s)")
        
        # Clean range header errors
        rar_removed, aria2_removed = clean_range_header_errors(dest_dir)
        if rar_removed > 0 or aria2_removed > 0:
            print_status(True, f"Cleaned {rar_removed} range-header-corrupted file(s)")
        
        # Resume aria2
        print_stage(2, "Resuming aria2 download...")
        success = aria2c_resume(dest_dir, concurrency=8)
        
        if success:
            test_archive(dest_dir, game_name)
            ff_manifest_path(dest_dir, game_name).unlink(missing_ok=True)
            if RICH_AVAILABLE and console:
                console.print(f"[green]✓ {game_name} complete![/green]")
            else:
                print(f"  ✓ {game_name} complete!")
        else:
            if RICH_AVAILABLE and console:
                console.print(f"[yellow]✗ {game_name} incomplete - re-run fitgrab --resume[/yellow]")
            else:
                print(f"  ✗ {game_name} incomplete - re-run fitgrab --resume")
    
    elapsed = time.time() - start_time
    if RICH_AVAILABLE and console:
        console.print(Panel(
            f"[green]Resume session complete[/green]\n"
            f"[dim]Time: {format_time(elapsed)}[/dim]",
            title="[bold green]Done[/bold green]",
            border_style="green",
            expand=False,
        ))
    else:
        print(f"\n  Resume session complete. Time: {format_time(elapsed)}")


def main():
    parser = argparse.ArgumentParser(
        prog="fitgrab",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Examples:\n"
            "  fitgrab https://fitgirl-repacks.site/god-of-war-ragnarok/\n"
            "  fitgrab https://fitgirl-repacks.site/stellar-blade/ --dir ~/Games\n"
            "  fitgrab https://paste.fitgirl-repacks.site/?<id>#<key> --dir ~/Games\n"
            "  fitgrab <url> --dry-run\n"
            "  fitgrab --resume              # scan for incomplete downloads\n"
            "  fitgrab --add-path /mnt/ssd   # add game path to config"
        ),
    )
    parser.add_argument("url", nargs="?", help="FitGirl game URL or paste URL (optional with --resume)")
    parser.add_argument(
        "--dir",
        default=None,
        help="Download directory (default: auto-detect from filename → ~/Games/<game>/)",
    )
    parser.add_argument("--dry-run", action="store_true")
    parser.add_argument(
        "--concurrency",
        type=int,
        default=DEFAULT_CONCURRENCY,
        help=f"Parallel contexts for URL resolution (default: {DEFAULT_CONCURRENCY})",
    )
    parser.add_argument(
        "--continue",
        dest="continue_download",
        action="store_true",
        help="Resume failed download by cleaning corrupted state and re-running aria2",
    )
    parser.add_argument(
        "--resume", "-r",
        action="store_true",
        help="Scan for incomplete downloads and prompt to resume",
    )
    parser.add_argument(
        "--add-path",
        type=str,
        metavar="PATH",
        help="Add a game directory path to config (for --resume scanning)",
    )
    args = parser.parse_args()
    
    # Handle --add-path
    if args.add_path:
        new_path = Path(args.add_path).expanduser()
        if not new_path.exists():
            print(f"Error: Directory does not exist: {new_path}")
            sys.exit(1)
        existing_paths = load_game_paths()
        if new_path not in existing_paths:
            existing_paths.append(new_path)
            save_game_paths(existing_paths)
            print(f"Added path: {new_path}")
        else:
            print(f"Path already in config: {new_path}")
        return
    
    # Handle --resume
    if args.resume:
        run_resume_mode()
        return
    
    # Normal mode requires URL
    if not args.url:
        parser.error("URL is required (use --resume to scan for incomplete downloads)")
    
    asyncio.run(run(args))


if __name__ == "__main__":
    try:
        main()
    except FitgrabError as e:
        logger.error(str(e))
        sys.exit(1)
    except KeyboardInterrupt:
        logger.info("Interrupted by user")
        sys.exit(0)
    except Exception as e:
        logger.error(f"Unexpected error: {e}")
        sys.exit(1)